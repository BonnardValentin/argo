# GitHub personal access token with `repo` scope (classic) or fine-grained
# equivalent. Used only to read PRs/issues.
GITHUB_TOKEN=

# Anthropic API key. Used for structured extraction.
ANTHROPIC_API_KEY=

# Model for extraction. Haiku is cheap and fast enough for this.
ARGOS_EXTRACTION_MODEL=claude-haiku-4-5-20251001

# Where markdown nodes are written. Relative paths resolve against the project
# root. Default: ./data/knowledge
ARGOS_DATA_DIR=./data/knowledge

# --- Step 3: embeddings + Redis vector search ---

# Redis Stack (vector search enabled). Default assumes a local dev instance:
# docker run -d -p 6379:6379 redis/redis-stack:latest
REDIS_URL=redis://localhost:6379/0
ARGOS_REDIS_INDEX=argos-nodes

# Embedding provider. Leave blank to auto-select: "openai" if an API key is
# present, else "hash" (deterministic offline fallback).
ARGOS_EMBEDDING_PROVIDER=

# Any OpenAI-compatible endpoint works (OpenAI, Ollama, vLLM, gateway proxies).
ARGOS_EMBEDDING_API_KEY=
ARGOS_EMBEDDING_BASE_URL=https://api.openai.com/v1
ARGOS_EMBEDDING_MODEL=text-embedding-3-small
# Vector dimensionality. Must match what the index was built with — change
# this and you must `kb index --reset`.
ARGOS_EMBEDDING_DIM=1536

# --- Step 4: Hermes Linker (graph edges) ---

# Claude model used for relation classification. Auto-selects the LLM backend
# when ANTHROPIC_API_KEY is set above; otherwise falls back to heuristic.
ARGOS_LINKER_MODEL=claude-haiku-4-5-20251001

# Minimum edge confidence. Edges below this are logged and dropped.
ARGOS_LINKER_MIN_CONFIDENCE=0.6

# Cosine threshold for the heuristic fallback (only used when no Anthropic
# key is available). Higher = fewer, stricter `related_to` edges.
ARGOS_LINKER_HEURISTIC_THRESHOLD=0.75
